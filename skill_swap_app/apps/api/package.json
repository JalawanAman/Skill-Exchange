{
  "name": "@skillswap/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:push": "drizzle-kit push:pg",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "logs": "tsx scripts/read-logs.ts",
    "seed:skills": "tsx scripts/seed-skills.ts",
    "seed:test-match": "tsx scripts/seed-test-match.ts"
  },
  "dependencies": {
    "@skillswap/shared": "workspace:*",
    "@clerk/express": "^1.0.0",
    "@neondatabase/serverless": "^0.9.0",
    "@upstash/redis": "^1.31.0",
    "cloudinary": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "resend": "^3.2.0",
    "socket.io": "^4.7.0",
    "svix": "^1.21.0",
    "ws": "^8.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
